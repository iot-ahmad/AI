# ─────────────────────────────────────────────
#  AI Social Media Content System — .env.example
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# ── OpenAI ───────────────────────────────────
# Get yours at https://platform.openai.com/api-keys
# gpt-3.5-turbo keeps costs very low (~$0.001 per run)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo

# ── Twitter / X ──────────────────────────────
# Create app at https://developer.twitter.com
# Needs OAuth 1.0a Read+Write permission
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# ── YouTube ───────────────────────────────────
# Download credentials JSON from Google Cloud Console
# Paste the entire JSON string here (minified)
YOUTUBE_CLIENT_SECRETS=

# ── Content settings ──────────────────────────
# Comma-separated niches to filter trends
NICHE_KEYWORDS=AI,motivation,business,productivity,personal finance

# ── Scheduler ────────────────────────────────
# How often to run the full pipeline (hours)
PIPELINE_INTERVAL_HOURS=6
TREND_INTERVAL_HOURS=12

# ── Storage ───────────────────────────────────
# Where generated videos are saved
OUTPUT_DIR=/tmp/output
